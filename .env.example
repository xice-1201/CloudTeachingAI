# 数据库配置
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# JWT 密钥 (RSA)
# 生成方式: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# 然后将内容粘贴到这里，注意保留换行符

JWT_PRIVATE_KEY=|
  -----BEGIN PRIVATE KEY-----
  YOUR_PRIVATE_KEY_HERE
  -----END PRIVATE KEY-----

JWT_PUBLIC_KEY=|
  -----BEGIN PUBLIC KEY-----
  YOUR_PUBLIC_KEY_HERE
  -----END PUBLIC KEY-----